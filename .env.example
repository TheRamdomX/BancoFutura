# Copia este archivo a `.env` y completa los valores reales.
# `.env` está en .gitignore — NUNCA lo commitees.

# ── SurrealDB ──────────────────────────────────────────────
SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=banco
SURREAL_DB=futura

# ── Google AI (Gemini) ─────────────────────────────────────
# Obtén una key en https://aistudio.google.com/apikey
GEMINI_API_KEY=<tu-api-key-de-google-ai-studio>
GEMINI_MODEL=gemma-4-31b-it

# ── MCP Server / Orquestador ───────────────────────────────
MCP_SERVER_PORT=8002
MCP_LOG_LEVEL=DEBUG

# ── Clasificador de intención (Fase 5, opcional) ───────────
INTENT_CLASSIFIER_URL=http://intent-classifier:8003
